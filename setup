#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
SENNEN_DIR="$ROOT_DIR/sennen"
MODE=""
ENABLE_CODEX=0
ENABLE_CLAUDE=0
ENABLE_CLAUDE_STANDALONE=0
TARGET_REPO=""
ASSUME_YES=0
GIT_CHOICE="auto"
UV_CHOICE="auto"
DVC_CHOICE="auto"
TRACKING_BACKEND="auto"
INSTALL_JOIN_SKILL="auto"
INSTALL_DB_SKILLS="auto"
RESOLVED_TWENTYMINDS_API_KEY=""

while [ $# -gt 0 ]; do
  case "$1" in
    --codex) ENABLE_CODEX=1; shift ;;
    --claude) ENABLE_CLAUDE=1; shift ;;
    --claude-standalone) ENABLE_CLAUDE_STANDALONE=1; shift ;;
    --yes) ASSUME_YES=1; shift ;;
    --git) GIT_CHOICE="yes"; shift ;;
    --no-git) GIT_CHOICE="no"; shift ;;
    --uv) UV_CHOICE="yes"; shift ;;
    --no-uv) UV_CHOICE="no"; shift ;;
    --dvc) DVC_CHOICE="yes"; shift ;;
    --no-dvc) DVC_CHOICE="no"; shift ;;
    --mlflow) TRACKING_BACKEND="mlflow"; shift ;;
    --no-tracking) TRACKING_BACKEND="none"; shift ;;
    -* ) echo "Unknown argument: $1" >&2; exit 1 ;;
    * )
      if [ -n "$TARGET_REPO" ]; then
        echo "Unexpected extra positional argument: $1" >&2
        exit 1
      fi
      TARGET_REPO="$1"
      shift
      ;;
  esac
done

if [ "$ENABLE_CLAUDE_STANDALONE" -eq 1 ] && { [ "$ENABLE_CODEX" -eq 1 ] || [ "$ENABLE_CLAUDE" -eq 1 ]; }; then
  echo "--claude-standalone cannot be combined with --claude or --codex" >&2
  exit 1
fi

if [ "$ENABLE_CLAUDE_STANDALONE" -eq 1 ]; then
  MODE="claude-standalone"
elif [ "$ENABLE_CODEX" -eq 1 ] && [ "$ENABLE_CLAUDE" -eq 1 ]; then
  MODE="both"
elif [ "$ENABLE_CODEX" -eq 1 ]; then
  MODE="codex"
elif [ "$ENABLE_CLAUDE" -eq 1 ]; then
  MODE="claude"
elif [ -n "$TARGET_REPO" ]; then
  MODE="both"
else
  MODE="both"
fi

print_banner() {
  cat <<'EOF'
          /\        /\
         /  \  /\  /  \
        /    \/  \/    \
       /                \
      /   /\      /\     \
     /   /  \____/  \     \

                sennen
             by 20minds.ai

EOF
}

print_banner

print_top_level_dir() {
  local repo="$1"
  local dir_name="$2"
  local context="$3"
  local dir_path="$repo/$dir_name"
  if [ -d "$dir_path" ]; then
    echo "  top-level directory: $dir_name ($context)"
  fi
}

prompt_for_secret() {
  local prompt="$1"
  local reply=""
  printf "%s " "$prompt" >&2
  if [ -t 0 ]; then
    stty -echo
  fi
  read -r reply
  if [ -t 0 ]; then
    stty echo
  fi
  printf "\n" >&2
  printf '%s' "$reply"
}

read_env_var() {
  local repo="$1"
  local key="$2"
  local env_file="$repo/.env"
  local value=""

  value="${!key:-}"
  if [ -n "$value" ]; then
    printf '%s' "$value"
    return
  fi

  if [ ! -f "$env_file" ]; then
    return
  fi

  value="$(awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, "", $0); print $0; exit }' "$env_file")"
  printf '%s' "$value"
}

resolve_twentyminds_api_key() {
  local repo="${1:-}"
  local existing_value=""

  if [ -n "$repo" ]; then
    existing_value="$(read_env_var "$repo" "TWENTYMINDS_API_KEY")"
  else
    existing_value="${TWENTYMINDS_API_KEY:-}"
  fi

  if [ -n "$existing_value" ]; then
    if [ -n "$repo" ]; then
      echo "Using existing TWENTYMINDS_API_KEY from the environment or $repo/.env"
      upsert_env_var "$repo" "TWENTYMINDS_API_KEY" "$existing_value"
    else
      echo "Using existing TWENTYMINDS_API_KEY from the environment"
    fi
    RESOLVED_TWENTYMINDS_API_KEY="$existing_value"
    return
  fi

  echo "Get a key at https://20minds.ai/settings/api-keys"
  existing_value="$(prompt_for_secret "Enter TWENTYMINDS_API_KEY:")"
  if [ -z "$existing_value" ]; then
    RESOLVED_TWENTYMINDS_API_KEY=""
    return
  fi

  export TWENTYMINDS_API_KEY="$existing_value"
  if [ -n "$repo" ]; then
    upsert_env_var "$repo" "TWENTYMINDS_API_KEY" "$existing_value"
    echo "Saved TWENTYMINDS_API_KEY to $repo/.env"
  fi
  RESOLVED_TWENTYMINDS_API_KEY="$existing_value"
}

prompt_join_skill_install() {
  local repo="${1:-}"
  if confirm "$(cat <<'EOF'
Install the optional conference-call assistant skill?
It lets the agent join live meetings, exchange messages in the call,
and share figures when appropriate.
EOF
)" "yes"; then
    echo
    INSTALL_JOIN_SKILL="yes"
    resolve_twentyminds_api_key "$repo"
  else
    echo
    INSTALL_JOIN_SKILL="no"
  fi
}

prompt_db_skills_install() {
  if confirm "$(cat <<'EOF'
Install the optional database research skills?
They add direct access to sources like PubMed, ClinicalTrials.gov,
ChEMBL, Open Targets, ClinVar, GEO, and related databases.
EOF
)" "yes"; then
    echo
    INSTALL_DB_SKILLS="yes"
  else
    echo
    INSTALL_DB_SKILLS="no"
  fi
}

upsert_env_var() {
  local repo="$1"
  local key="$2"
  local value="$3"
  local env_file="$repo/.env"
  local tmp_file
  tmp_file="$(mktemp)"

  if [ -f "$env_file" ]; then
    awk -v key="$key" '$0 ~ ("^" key "=") { next } { print }' "$env_file" > "$tmp_file"
  fi
  if [ -s "$tmp_file" ]; then
    mv "$tmp_file" "$env_file"
    printf "\n%s=%s\n" "$key" "$value" >> "$env_file"
  else
    rm -f "$tmp_file"
    printf "%s=%s\n" "$key" "$value" > "$env_file"
  fi
}

install_claude_plugin_dir() {
  local plugin_dir="$1"
  shift
  local excluded=("$@")
  mkdir -p "$(dirname "$plugin_dir")"
  if [ "${#excluded[@]}" -eq 0 ]; then
    ln -sfn "$SENNEN_DIR" "$plugin_dir"
    return
  fi
  rm -rf "$plugin_dir"
  mkdir -p "$plugin_dir"
  cp -R "$SENNEN_DIR"/. "$plugin_dir"/
  local excluded_skill=""
  for excluded_skill in "${excluded[@]}"; do
    case "$excluded_skill" in
      sen-join)
        rm -rf "$plugin_dir/skills/sen-join"
        rm -f "$plugin_dir/commands/join.md"
        ;;
      db-*)
        rm -rf "$plugin_dir/skills/$excluded_skill"
        ;;
    esac
  done
}

install_claude_standalone_commands() {
  local target_repo="$1"
  shift
  local excluded=("$@")
  local commands_dir="$target_repo/.claude/commands"
  local skills_dir="$target_repo/.claude/skills"
  local source_dir="$SENNEN_DIR/commands"
  local source_skills_dir="$SENNEN_DIR/skills"

  mkdir -p "$commands_dir"
  rm -rf "$skills_dir"
  if [ "${#excluded[@]}" -eq 0 ]; then
    ln -sfn "$source_skills_dir" "$skills_dir"
  else
    mkdir -p "$skills_dir"
    cp -R "$source_skills_dir"/. "$skills_dir"/
    local excluded_skill=""
    for excluded_skill in "${excluded[@]}"; do
      rm -rf "$skills_dir/$excluded_skill"
    done
  fi
  for source_path in "$source_dir"/*.md; do
    [ -f "$source_path" ] || continue
    local command_name
    local command_stem
    command_name="$(basename "$source_path")"
    command_stem="${command_name%.md}"
    local skip_command=0
    local excluded_skill=""
    if [ "${#excluded[@]}" -gt 0 ]; then
      for excluded_skill in "${excluded[@]}"; do
        if [ "$excluded_skill" = "sen-join" ] && [ "$command_name" = "join.md" ]; then
          skip_command=1
        fi
      done
    fi
    if [ "$skip_command" -eq 1 ]; then
      continue
    fi
    cp "$source_path" "$commands_dir/sen-$command_stem.md"
  done
}

install_claude_global_skills() {
  local home_dir="$1"
  shift
  local excluded=("$@")
  local claude_dir="$home_dir/.claude"
  local skills_dir="$claude_dir/skills"
  local source_skills_dir="$SENNEN_DIR/skills"
  local commands_dir="$claude_dir/commands"
  local plugin_dir="$claude_dir/plugins/sennen"

  mkdir -p "$claude_dir"
  rm -rf "$plugin_dir"
  if [ -d "$commands_dir" ]; then
    rm -f "$commands_dir"/sen-*.md
  fi

  rm -rf "$skills_dir"
  if [ "${#excluded[@]}" -eq 0 ]; then
    ln -sfn "$source_skills_dir" "$skills_dir"
  else
    mkdir -p "$skills_dir"
    cp -R "$source_skills_dir"/. "$skills_dir"/
    local excluded_skill=""
    for excluded_skill in "${excluded[@]}"; do
      rm -rf "$skills_dir/$excluded_skill"
    done
  fi
}

install_codex_global_plugin() {
  local home_dir="$1"
  shift
  python3 "$SENNEN_DIR/scripts/install_personal.py" --home "$home_dir" --quiet "$@"
}

join_skill_flag() {
  if [ "$INSTALL_JOIN_SKILL" = "yes" ]; then
    printf '1'
  else
    printf '0'
  fi
}

db_skill_flag() {
  if [ "$INSTALL_DB_SKILLS" = "yes" ]; then
    printf '1'
  else
    printf '0'
  fi
}

exclude_skill_args() {
  local args=()
  local join_flag db_flag
  join_flag="$(join_skill_flag)"
  db_flag="$(db_skill_flag)"

  if [ "$join_flag" -eq 0 ]; then
    args+=(--exclude-skill sen-join)
  fi
  if [ "$db_flag" -eq 0 ]; then
    for skill_dir in "$SENNEN_DIR"/skills/db-*; do
      [ -d "$skill_dir" ] || continue
      args+=(--exclude-skill "$(basename "$skill_dir")")
    done
  fi

  if [ "${#args[@]}" -gt 0 ]; then
    printf '%s\n' "${args[@]}"
  fi
}

install_repo_targets() {
  local repo="$1"
  local join_flag
  join_flag="$(join_skill_flag)"
  local exclude_args=()
  while IFS= read -r line; do
    [ -n "$line" ] && exclude_args+=("$line")
  done < <(exclude_skill_args)

  if [ "$MODE" = "codex" ] || [ "$MODE" = "both" ]; then
    if [ "$join_flag" -eq 1 ] && [ "${#exclude_args[@]}" -eq 0 ]; then
      python3 "$SENNEN_DIR/scripts/install_local.py" "$repo" --force --quiet
    else
      python3 "$SENNEN_DIR/scripts/install_local.py" "$repo" --copy --force --quiet "${exclude_args[@]}"
    fi
    print_top_level_dir "$repo" ".agents" "codex skills"
  fi

  if [ "$MODE" = "claude" ] || [ "$MODE" = "both" ]; then
    local excluded_skills_only=()
    local arg=""
    if [ "${#exclude_args[@]}" -gt 0 ]; then
      for arg in "${exclude_args[@]}"; do
        case "$arg" in
          --exclude-skill) ;;
          *) excluded_skills_only+=("$arg") ;;
        esac
      done
    fi
    if [ "${#excluded_skills_only[@]}" -gt 0 ]; then
      install_claude_plugin_dir "$repo/plugins/sennen" "${excluded_skills_only[@]}"
    else
      install_claude_plugin_dir "$repo/plugins/sennen"
    fi
    print_top_level_dir "$repo" "plugins" "claude plugin install"
  fi

  if [ "$MODE" = "claude-standalone" ]; then
    local excluded_skills_only=()
    local arg=""
    if [ "${#exclude_args[@]}" -gt 0 ]; then
      for arg in "${exclude_args[@]}"; do
        case "$arg" in
          --exclude-skill) ;;
          *) excluded_skills_only+=("$arg") ;;
        esac
      done
    fi
    if [ "${#excluded_skills_only[@]}" -gt 0 ]; then
      install_claude_standalone_commands "$repo" "${excluded_skills_only[@]}"
    else
      install_claude_standalone_commands "$repo"
    fi
    print_top_level_dir "$repo" ".claude" "claude standalone install"
  fi
}

print_repo_summary() {
  local repo="$1"
  echo
  echo "Ready."
  echo "  repo: $repo"
  if [ "$MODE" = "codex" ]; then
    echo "  codex: enabled"
    echo "  codex skills: $repo/.agents/skills"
  elif [ "$MODE" = "claude" ]; then
    echo "  claude: $repo/plugins/sennen"
    echo "  run: claude --plugin-dir $repo/plugins/sennen"
  elif [ "$MODE" = "claude-standalone" ]; then
    echo "  claude: standalone commands in .claude/commands"
  else
    echo "  codex: enabled"
    echo "  codex skills: $repo/.agents/skills"
    echo "  claude: $repo/plugins/sennen"
    echo "  claude run: claude --plugin-dir $repo/plugins/sennen"
  fi
}

install_global_targets() {
  local join_flag
  join_flag="$(join_skill_flag)"
  local exclude_args=()
  while IFS= read -r line; do
    [ -n "$line" ] && exclude_args+=("$line")
  done < <(exclude_skill_args)

  if [ "$MODE" = "codex" ] || [ "$MODE" = "both" ]; then
    if [ "${#exclude_args[@]}" -gt 0 ]; then
      install_codex_global_plugin "$HOME" "${exclude_args[@]}"
    else
      install_codex_global_plugin "$HOME"
    fi
  fi

  if [ "$MODE" = "claude" ] || [ "$MODE" = "both" ]; then
    local excluded_skills_only=()
    local arg=""
    if [ "${#exclude_args[@]}" -gt 0 ]; then
      for arg in "${exclude_args[@]}"; do
        case "$arg" in
          --exclude-skill) ;;
          *) excluded_skills_only+=("$arg") ;;
        esac
      done
    fi
    if [ "${#excluded_skills_only[@]}" -gt 0 ]; then
      install_claude_global_skills "$HOME" "${excluded_skills_only[@]}"
    else
      install_claude_global_skills "$HOME"
    fi
  fi
}

print_global_summary() {
  if [ "$MODE" = "codex" ]; then
    echo "sennen ready (codex)"
    echo "  codex skills: $HOME/.codex/skills"
  elif [ "$MODE" = "claude" ]; then
    echo "sennen ready (claude)"
    echo "  skills: $HOME/.claude/skills"
  else
    echo "sennen ready (codex + claude)"
    echo "  codex skills: $HOME/.codex/skills"
    echo "  claude skills: $HOME/.claude/skills"
  fi
}

confirm() {
  local prompt="$1"
  local default_answer="$2"
  local reply=""

  if [ "$ASSUME_YES" -eq 1 ]; then
    [ "$default_answer" = "yes" ] && return 0
    return 1
  fi

  if [ "$default_answer" = "yes" ]; then
    printf "%s [Y/n] " "$prompt"
  else
    printf "%s [y/N] " "$prompt"
  fi
  read -r reply
  reply="${reply:-}"

  if [ -z "$reply" ]; then
    [ "$default_answer" = "yes" ] && return 0
    return 1
  fi

  case "$reply" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

choice_enabled() {
  local choice="$1"
  local prompt="$2"
  local default_answer="$3"

  case "$choice" in
    yes) return 0 ;;
    no) return 1 ;;
    auto) confirm "$prompt" "$default_answer"; return $? ;;
    *) return 1 ;;
  esac
}

select_tracking_backend() {
  local reply=""

  case "$TRACKING_BACKEND" in
    mlflow|none)
      TRACKING_SELECTED="$TRACKING_BACKEND"
      return
      ;;
  esac

  if [ "$ASSUME_YES" -eq 1 ]; then
    TRACKING_SELECTED="none"
    return
  fi

  printf "Enable MLflow? [y/N] "
  read -r reply
  reply="${reply:-}"

  case "$reply" in
    y|Y|yes|YES|m|M|mlflow|MLFLOW) TRACKING_SELECTED="mlflow" ;;
    *) TRACKING_SELECTED="none" ;;
  esac
}

repo_has_git() {
  git -C "$1" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

dvc_available() {
  local repo="${1:-}"
  if command -v dvc >/dev/null 2>&1; then
    return 0
  fi
  if [ -n "$repo" ] && command -v uv >/dev/null 2>&1 && [ -f "$repo/pyproject.toml" ]; then
    (
      cd "$repo"
      uv run dvc version >/dev/null 2>&1
    ) && return 0
  fi
  if command -v uv >/dev/null 2>&1; then
    uv tool run --from dvc dvc version >/dev/null 2>&1 && return 0
  fi
  return 1
}

run_dvc() {
  local repo="$1"
  shift
  if command -v dvc >/dev/null 2>&1; then
    (
      cd "$repo"
      dvc "$@"
    )
    return
  fi
  if [ -f "$repo/pyproject.toml" ]; then
    (
      cd "$repo"
      uv run dvc "$@"
    )
    return
  fi
  uv tool run --from dvc dvc "$@"
}

sanitize_project_name() {
  local raw
  local sanitized
  raw="$(basename "$(cd "$1" && pwd)")"
  sanitized="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9._-' '-')"
  sanitized="$(printf '%s' "$sanitized" | sed -E 's/^[^a-z0-9]+//; s/[^a-z0-9]+$//')"
  if [ -z "$sanitized" ]; then
    sanitized="sennen-project"
  fi
  printf '%s' "$sanitized"
}

ensure_pyproject() {
  local repo="$1"
  local pyproject="$repo/pyproject.toml"
  local project_name

  project_name="$(sanitize_project_name "$repo")"

  if [ -f "$pyproject" ]; then
    if grep -q '^name = "-"$' "$pyproject"; then
      python3 - "$pyproject" "$project_name" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
name = sys.argv[2]
text = path.read_text()
text = text.replace('name = "-"', f'name = "{name}"', 1)
path.write_text(text)
PY
    fi
    return 0
  fi

  if [ -f "$repo/requirements.txt" ] || [ -f "$repo/requirements.in" ]; then
    echo "requirements.txt-style dependency tracking is not supported by setup; use pyproject.toml with uv instead"
  fi

  if ! confirm "No pyproject.toml found in $repo. Create one for uv-managed dependencies?" "yes"; then
    return 1
  fi

  cat > "$pyproject" <<EOF
[project]
name = "$project_name"
version = "0.1.0"
requires-python = ">=3.10"
dependencies = []
EOF
  return 0
}

uv_add_dependency() {
  local repo="$1"
  local package="$2"
  (
    cd "$repo"
    uv add "$package"
  )
}

ensure_gitignore_entry() {
  local repo="$1"
  local entry="$2"
  local gitignore="$repo/.gitignore"

  if [ ! -f "$gitignore" ]; then
    printf "%s\n" "$entry" > "$gitignore"
    return
  fi

  if grep -Fxq "$entry" "$gitignore"; then
    return
  fi

  if [ -s "$gitignore" ]; then
    printf "\n%s\n" "$entry" >> "$gitignore"
  else
    printf "%s\n" "$entry" >> "$gitignore"
  fi
}

ensure_default_gitignore() {
  local repo="$1"

  ensure_gitignore_entry "$repo" "__pycache__/"
  ensure_gitignore_entry "$repo" "*.pyc"
  ensure_gitignore_entry "$repo" "*.pyo"
  ensure_gitignore_entry "$repo" "*.pyd"
  ensure_gitignore_entry "$repo" ".venv/"
  ensure_gitignore_entry "$repo" ".pytest_cache/"
  ensure_gitignore_entry "$repo" ".mypy_cache/"
  ensure_gitignore_entry "$repo" ".ruff_cache/"
  ensure_gitignore_entry "$repo" ".coverage"
  ensure_gitignore_entry "$repo" "htmlcov/"
  ensure_gitignore_entry "$repo" "mlruns/"
  ensure_gitignore_entry "$repo" "mlflow.db"
  ensure_gitignore_entry "$repo" ".DS_Store"
  ensure_gitignore_entry "$repo" ".env"
}

if [ -n "$TARGET_REPO" ]; then
  mkdir -p "$TARGET_REPO"

  HAS_GIT=0
  HAS_VENV=0
  HAS_DVC=0
  HAS_UV=0
  HAS_DVC_BIN=0
  HAS_PYPROJECT=0
  TRACKING_SELECTED="none"
  TRACKING_READY="none"

  repo_has_git "$TARGET_REPO" && HAS_GIT=1
  [ -d "$TARGET_REPO/.venv" ] && HAS_VENV=1
  [ -d "$TARGET_REPO/.dvc" ] && HAS_DVC=1
  [ -f "$TARGET_REPO/pyproject.toml" ] && HAS_PYPROJECT=1
  command -v uv >/dev/null 2>&1 && HAS_UV=1
  dvc_available "$TARGET_REPO" && HAS_DVC_BIN=1

  prompt_db_skills_install
  prompt_join_skill_install "$TARGET_REPO"

  if [ "$HAS_GIT" -eq 0 ] && choice_enabled "$GIT_CHOICE" "Initialize Git?" "yes"; then
    git -C "$TARGET_REPO" init >/dev/null
    HAS_GIT=1
  fi
  [ "$HAS_GIT" -eq 1 ] && print_top_level_dir "$TARGET_REPO" ".git" "git initialization"
  install_repo_targets "$TARGET_REPO"

  ensure_default_gitignore "$TARGET_REPO"

  if [ "$HAS_VENV" -eq 0 ]; then
    if [ "$HAS_UV" -eq 1 ]; then
      if choice_enabled "$UV_CHOICE" "Create .venv with uv?" "yes"; then
        (
          cd "$TARGET_REPO"
          uv venv .venv >/dev/null
        )
        HAS_VENV=1
      fi
    else
      echo "uv not found; skipping .venv creation"
    fi
  fi
  if [ "$HAS_VENV" -eq 1 ]; then
    print_top_level_dir "$TARGET_REPO" ".venv" "uv virtualenv setup"
  fi

  if [ "$HAS_UV" -eq 0 ]; then
    echo "uv not found; skipping Python dependency installation"
  fi

  echo
  if choice_enabled "$DVC_CHOICE" "Enable DVC?" "yes"; then
    if [ "$HAS_UV" -eq 0 ]; then
      echo "uv not found; skipping DVC install"
    elif ensure_pyproject "$TARGET_REPO"; then
      HAS_PYPROJECT=1
      echo "Adding dvc..."
      uv_add_dependency "$TARGET_REPO" "dvc"
      echo "dvc added"
      HAS_DVC_BIN=1
      if [ "$HAS_GIT" -eq 1 ]; then
        if [ "$HAS_DVC" -eq 0 ]; then
          if confirm "Run dvc init?" "yes"; then
            run_dvc "$TARGET_REPO" init >/dev/null
            HAS_DVC=1
            echo "dvc initialized"
          fi
        else
          echo "dvc already initialized"
        fi
      else
        echo "Git repo not available; skipping DVC init"
      fi
    fi
  fi
  [ "$HAS_DVC" -eq 1 ] && print_top_level_dir "$TARGET_REPO" ".dvc" "dvc initialization"

  select_tracking_backend
  if [ "$TRACKING_SELECTED" = "mlflow" ]; then
    if [ "$HAS_UV" -eq 0 ]; then
      echo "uv not found; skipping $TRACKING_SELECTED install"
    elif ensure_pyproject "$TARGET_REPO"; then
      HAS_PYPROJECT=1
      echo "Adding mlflow..."
      uv_add_dependency "$TARGET_REPO" "$TRACKING_SELECTED"
      echo "mlflow added"
      TRACKING_READY="$TRACKING_SELECTED"
    fi
  fi

  print_repo_summary "$TARGET_REPO"
  [ "$HAS_DVC" -eq 1 ] && echo "  dvc: enabled"
  [ "$TRACKING_READY" = "mlflow" ] && echo "  mlflow: sqlite:///mlflow.db"
  exit 0
fi

prompt_db_skills_install
prompt_join_skill_install ""

if [ "$MODE" = "codex" ]; then
  install_global_targets
  print_global_summary
elif [ "$MODE" = "claude" ]; then
  install_global_targets
  print_global_summary
elif [ "$MODE" = "claude-standalone" ]; then
  echo "setup --claude-standalone requires a repo path" >&2
  exit 1
else
  install_global_targets
  print_global_summary
fi
